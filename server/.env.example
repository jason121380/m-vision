# Postgres connection（本地 docker-compose 預設）
DATABASE_URL=postgres://mvision:mvision@localhost:5432/mvision

# 給 cookie session 簽章用（隨意 32+ 字元）
SESSION_SECRET=change-me-to-a-long-random-string

# Hono server 監聽 port
PORT=3001

# 允許的前端 origin（CORS）。多個用逗號隔開
CORS_ORIGINS=http://localhost:5173,https://m-vision.zeabur.app

# Sheet migration 用：來源 CSV base（與前端 src/config.ts 同一份 publish-to-web）
SHEET_CSV_BASE=https://docs.google.com/spreadsheets/d/e/2PACX-1vTFQckgyvf1EHhsOPeI8X1SPsaqQTert9W53cOfeTHy3TkGseK1bfzI4jn7euXKS5CGlgYxJ18Ml2I-/pub

# Apps Script PDF endpoint（保留 PDF 上傳到 Drive 的流程）
PDF_UPLOAD_ENDPOINT=https://script.google.com/macros/s/AKfycbwLQeC7F5Ke5LhDgyrMVgnJjpQ0FPHO3FhZuCp3DI5NN9848_0A14Z-1gAV0wi8OSI/exec
