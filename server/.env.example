# Hono server 監聽 port（Zeabur 會自動注入 PORT）
PORT=3001

# 資料存放目錄。本地預設 server/data/，部署時建議掛 volume 進來。
DATA_DIR=./data

# 第一次啟動時自動建一組 admin（已存在則略過）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234

# 允許的前端 origin（CORS）。同源部署可不設
CORS_ORIGINS=

# Sheet migration 用：來源 CSV base
SHEET_CSV_BASE=https://docs.google.com/spreadsheets/d/e/2PACX-1vTFQckgyvf1EHhsOPeI8X1SPsaqQTert9W53cOfeTHy3TkGseK1bfzI4jn7euXKS5CGlgYxJ18Ml2I-/pub

# Apps Script PDF endpoint（保留 PDF 上傳到 Drive 的流程）
PDF_UPLOAD_ENDPOINT=https://script.google.com/macros/s/AKfycbwLQeC7F5Ke5LhDgyrMVgnJjpQ0FPHO3FhZuCp3DI5NN9848_0A14Z-1gAV0wi8OSI/exec
